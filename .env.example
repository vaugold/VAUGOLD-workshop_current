# VITE_SUPABASE_URL — URL твоего проекта Supabase (например https://xxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# VITE_SUPABASE_ANON_KEY — анонимный публичный ключ (Settings → API → Project API keys → anon public)
# ВАЖНО: только anon-ключ. Никогда не клади service_role в клиентский .env.
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here